<Ui xmlns="http://www.runewaker.com/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.runewaker.com/..\..\WorldXML\UI.xsd">
	<Frame name="COMBATENGINE_durabilityTemplate" hidden="true" frameStrata="HIGH" movable="false" enableMouse="false" scale="1" dependencies="true" virtual="true">
		<Size>
			<AbsDimension x="24" y="13"/>
		</Size>
		<Anchors>
			<Anchor point="TOPLEFT" x="-10" y="-5"/>
		</Anchors>
		<Layers>
			<Layer level="BACKGROUND">
				<Texture name="$parentBG" file="Interface\addons\CombatEngine\texture\Durability\bg.tga">
					<Anchors>
						<Anchor point="TOPLEFT"/>
						<Anchor point="BOTTOMRIGHT"/>
					</Anchors>
					<Color a="0.65"/>
				</Texture>
			</Layer>
			<Layer level="ARTWORK">
				<FontString name="$parentValue" hidden="false" inherits="GameFontNormal" justifyH="CENTER" weight="BOLD" outline="NORMAL" text="110/110">
					<Size><AbsDimension y="22"/></Size>
					<Anchors><Anchor point="CENTER" y="0"/></Anchors>
					<FontHeight><AbsValue val="11"/></FontHeight>
					<Color hex="00FFFF"/>
				</FontString>
			</Layer>
		</Layers>
		<Scripts>
			<OnShow>
				CE_durability_OnShow(this);
			</OnShow>
			<OnLoad>
				CE_durability_OnLoad(this);
			</OnLoad>
			<OnEvent>
				CE_durability_OnEvent(this, event);
			</OnEvent>
		</Scripts>
	</Frame>

	<Frame name="CE_DUR_01" parent="EquipMainHandSlot" inherits="COMBATENGINE_durabilityTemplate" hidden="false"/>
