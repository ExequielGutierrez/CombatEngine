<!--Expand-->
	<CheckButton name="CE_ART_EXPAND" hidden="false" frameStrata="HIGH" parent="CE_FRAME_FAST_ROGUE" movable="false" enableMouse="true" alpha="1">
    <Size>
        <AbsDimension y="16" x="16"/>
    </Size>
    <Anchors>
        <Anchor point="TOPRIGHT" relativePoint="TOPRIGHT" relativeTo="CE_FRAME_FAST_ROGUE">
            <Offset>
                <RelDimension x="-5" y="5" />
            </Offset>
        </Anchor>
    </Anchors>
		<Scripts>
			<OnEnter>
				GameTooltip:SetOwner(this,"ANCHOR_BOTTOMRIGHT",0,0);
				if( this:IsChecked() ) then
					GameTooltip:SetText(_G.CE_LANG.Tooltip.CloseBuffs, 0.9, 0.4, 0 );
				else
					GameTooltip:SetText(_G.CE_LANG.Tooltip.OpenBuffs, 0.9, 0.4, 0 );
				end
				GameTooltip:Show();
			</OnEnter>
			<OnClick>
				if( this:IsChecked() ) then
					CE_FRAME_FAST_BUFFS:Show();
					GameTooltip:SetText(_G.CE_LANG.Tooltip.CloseBuffs, 0.9, 0.4, 0 );
				else
					CE_FRAME_FAST_BUFFS:Hide();
					GameTooltip:SetText(_G.CE_LANG.Tooltip.OpenBuffs, 0.9, 0.4, 0 );
				end
			</OnClick>
			<OnLeave>
				GameTooltip:Hide();
			</OnLeave>
		</Scripts>
		<NormalTexture file="Interface\addons\CombatEngine\texture\Arrow_Expand.tga"/>
		<HighlightTexture file="Interface\addons\CombatEngine\texture\Arrow_Expand.tga" alphaMode="ADD"/>
		<CheckedTexture file="Interface\addons\CombatEngine\texture\Arrow_Contract.tga"/>
	</CheckButton>

