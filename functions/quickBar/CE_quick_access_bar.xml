<!--MOVE-->
	<Button name="CE_ART_QUICK_MOVE" hidden="false" frameStrata="HIGH" parent="CE_FRAME_FAST_ROGUE" movable="false" enableMouse="true" alpha="1">
    <Size>
        <AbsDimension y="16" x="16"/>
    </Size>
    <Anchors>
        <Anchor point="BOTTOMRIGHT" relativePoint="BOTTOMRIGHT" relativeTo="CE_FRAME_FAST_ROGUE">
            <Offset>
                <RelDimension x="-5" y="-5" />
            </Offset>
        </Anchor>
    </Anchors>
    <Scripts>   
		<OnMouseDown>
		CE_FRAME_FAST_ROGUE_BACKGROUND:StartMoving("TOPLEFT");
        </OnMouseDown>
        <OnMouseUp>
		CE_FRAME_FAST_ROGUE_BACKGROUND:StopMovingOrSizing();	
		CE_SAVE_QUICK_BAR_POSITON();
        </OnMouseUp>
    </Scripts>
    <NormalTexture file="Interface\addons\CombatEngine\texture\MOVE.tga"/>
</Button> 

<!--PERFECT SLIDE-->
	<Button name="CE_ART_PERFECT_SLIDE_TOGGLE" hidden="false" frameStrata="HIGH" parent="CE_FRAME_FAST_ROGUE" movable="false" enableMouse="true" alpha="1">
    <Size>
        <AbsDimension y="40" x="40"/>
    </Size>
    <Anchors>
        <Anchor point="LEFT" relativePoint="LEFT" relativeTo="CE_FRAME_FAST_ROGUE">
            <Offset>
                <RelDimension x="10" y="0" />
            </Offset>
        </Anchor>
    </Anchors>
    <Scripts>   
        <OnClick>
            if _G.C_EngineSettings.Perfect_Slide == false or _G.C_EngineSettings.Perfect_Slide == nil then
                --CE_SLIDE_ON_SYSTEM_TEXT()
                _G.C_EngineSettings.Perfect_Slide = true
                CE_ART_PERFECT_SLIDE_TOGGLE:LockPushed();
				GameTooltip:SetOwner(this,"ANCHOR_BOTTOMRIGHT",0,0);
				GameTooltip:SetText(GetReplaceSystemKeyword("[1491731]") .. " |cff00ff00ON|r");
				GameTooltip:Show();
            elseif _G.C_EngineSettings.Perfect_Slide == true then
                --CE_SLIDE_OFF_SYSTEM_TEXT()
                _G.C_EngineSettings.Perfect_Slide = false
                 CE_ART_PERFECT_SLIDE_TOGGLE:UnlockPushed();
				GameTooltip:SetOwner(this,"ANCHOR_BOTTOMRIGHT",0,0);
				GameTooltip:SetText(GetReplaceSystemKeyword("[1491731]") .. " |cff808080OFF|r");
				GameTooltip:Show();
            end
        </OnClick>     
        <OnEnter>
			if _G.C_EngineSettings.Perfect_Slide then
				GameTooltip:SetOwner(this,"ANCHOR_BOTTOMRIGHT",0,0);
				GameTooltip:SetText(GetReplaceSystemKeyword("[1491731]") .. " |cff00ff00ON|r");
				GameTooltip:Show();
			else 
				GameTooltip:SetOwner(this,"ANCHOR_BOTTOMRIGHT",0,0);
				GameTooltip:SetText(GetReplaceSystemKeyword("[1491731]") .. " |cff808080OFF|r");
				GameTooltip:Show();
			end
        </OnEnter>
        <OnLeave>
			GameTooltip:Hide();    
        </OnLeave>		
    </Scripts>
    <NormalTexture file="Interface\addons\CombatEngine\texture\SLIDE_OFF.tga"/>
    <PushedTexture file="Interface\addons\CombatEngine\texture\SLIDE_ON.tga"/>
	<HighlightTexture file="Interface\addons\CombatEngine\texture\SLIDE_OFF.tga" alphaMode="ADD"/>
</Button>  


<!--AOE-->
	<Button name="CE_ART_QUICK_AOE" hidden="false" frameStrata="HIGH" parent="CE_FRAME_FAST_ROGUE" movable="false" enableMouse="true" alpha="1">
    <Size>
        <AbsDimension y="40" x="40"/>
    </Size>
    <Anchors>
        <Anchor point="LEFT" relativePoint="RIGHT" relativeTo="CE_ART_PERFECT_SLIDE_TOGGLE">
            <Offset>
                <RelDimension x="3" y="0" />
            </Offset>
        </Anchor>
    </Anchors>
    <Scripts>   
        <OnClick>
            if _G.C_EngineSettings.AOE == false then
				--CE_AOE_ON_SYSTEM_TEXT();
				_G.C_EngineSettings.AOE = true
				_G.CE_AOE_ON = true
                CE_ART_QUICK_AOE:LockPushed();
				CE_BUTTON_AOE:SetChecked(true);
				GameTooltip:SetOwner(this,"ANCHOR_BOTTOMRIGHT",0,0);
				GameTooltip:SetText(_G.CE_LANG.Tooltip.AoeSkills .. ": ON", 1, 0.5, 0.3 );
				GameTooltip:Show(); 
            elseif _G.C_EngineSettings.AOE == true then
                --CE_AOE_OFF_SYSTEM_TEXT();
                _G.C_EngineSettings.AOE = false
				_G.CE_AOE_ON = false
                 CE_ART_QUICK_AOE:UnlockPushed();
				CE_BUTTON_AOE:SetChecked(false);
				GameTooltip:SetOwner(this,"ANCHOR_BOTTOMRIGHT",0,0);
				GameTooltip:SetText(_G.CE_LANG.Tooltip.AoeSkills .. ": OFF", 0.7, 0.7, 0.7 );
				GameTooltip:Show(); 
            end
        </OnClick>       
        <OnEnter>   
			if _G.C_EngineSettings.AOE then
				GameTooltip:SetOwner(this,"ANCHOR_BOTTOMRIGHT",0,0);
				GameTooltip:SetText(_G.CE_LANG.Tooltip.AoeSkills .. ": ON", 1, 0.5, 0.3 );
				GameTooltip:Show(); 
			else 
				GameTooltip:SetOwner(this,"ANCHOR_BOTTOMRIGHT",0,0);
				GameTooltip:SetText(_G.CE_LANG.Tooltip.AoeSkills .. ": OFF", 0.7, 0.7, 0.7 );
				GameTooltip:Show(); 
			end
        </OnEnter>
        <OnLeave>
            GameTooltip:Hide();    
        </OnLeave>	
    </Scripts>
    <NormalTexture file="Interface\addons\CombatEngine\texture\AOE_OFF.tga"/>
    <PushedTexture file="Interface\addons\CombatEngine\texture\AOE_ON.tga"/>
	<HighlightTexture file="Interface\addons\CombatEngine\texture\AOE_OFF.tga" alphaMode="ADD"/>
</Button>  

